---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Epilogue:wght@400;700;900&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;1,9..144,400;1,9..144,700&display=swap" rel="stylesheet" />
</head>
<body>

  <div id="cursor"></div>

  <!-- NAV -->
  <nav>
    <div class="nav-logo">jack.hartzler<span>.dev</span></div>
    <ul>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#resume">Resume</a></li>
      <li><a href="#tech">Tech</a></li>
      <li><a href="#about">About</a></li>
    </ul>
  </nav>

  <!-- TICKER -->
  <div class="ticker-bar">
    <div class="ticker-track">
      <span class="ticker-item">Full Stack Engineer</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Ruby on Rails</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">TypeScript</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Mentor</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Fintech &amp; SaaS</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Volunteer</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Full Stack Engineer</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Ruby on Rails</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">TypeScript</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Mentor</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Fintech &amp; SaaS</span><span class="ticker-dot">✦</span>
      <span class="ticker-item">Volunteer</span><span class="ticker-dot">✦</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow">Portfolio · jack.hartzler.dev</div>
      <h1 class="hero-name">
        Jack<br />
        <span class="line2">Hartzler.</span>
      </h1>
      <div class="hero-title"><span id="typewriter-text"></span><span class="typewriter-cursor">▌</span></div>
        <p class="hero-desc">Hi, I'm Jack. At work, I build software that people depend on to do their jobs. Currently, that means loan officers processing auto refi's and lender integrations to get our customers the best possible rates. In the past, I worked on enterprise SaaS for some of the largest customer experience teams in the world. I love backend coding but I'm comfortable the whole way up and down the stack. Off work, I'm a longtime volunteer mentor for college students and teens — and that's why I'm building RoomRally, a party game platform for in-person connection between young people and the adults who support them.</p>
      <div class="hero-ctas">
        <a href="#projects" class="btn btn-primary">See My Work</a>
        <a href="#resume" class="btn btn-secondary">View Resume</a>
      </div>
    </div>
    <div class="hero-right">
      <div class="photo-frame">
        <img src="/profilepic.png" alt="Jack Hartzler" class="photo-color" />
        <img src="/profilepic.png" alt="" class="photo-sepia" aria-hidden="true" />
      </div>
      <div class="hero-bg-text" id="ghostLetter">J</div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects">
    <div class="section-header" data-num="01">
      <span class="section-num">01 /</span>
      <h2 class="section-title"><span class="section-title-accent">Side Project</span></h2>
    </div>
    <div class="project-feature">
      <div class="project-feature-main">
        <span class="project-tag">Web App</span>
        <h3>RoomRally</h3>
        <p>A real-time multiplayer party game platform for youth workers, teachers, and camp counselors. Players join via room codes on their phones while a shared screen drives the action. Built for safe, moderated use in mixed group settings.</p>
        <div class="project-stack">
          <span class="stack-pill">Rails</span>
          <span class="stack-pill">Turbo Streams</span>
          <span class="stack-pill">WebSockets</span>
          <span class="stack-pill">Redis</span>
          <span class="stack-pill">Hotwire</span>
          <span class="stack-pill">Stimulus</span>
        </div>
        <a href="#" class="project-link">View Project →</a>
        <div class="project-active-badge">
          <span class="active-dot"></span>
          Under Active Development — More Coming Soon
        </div>
      </div>
      <div class="project-feature-games">
        <div class="games-label">Features</div>
        <div class="game-item">
          <div class="game-item-status live">Live</div>
          <h4>Comedy Clash</h4>
          <p>A Quiplash-style prompt game where players submit the funniest answers and vote on the best.</p>
        </div>
        <div class="game-item">
          <div class="game-item-status live">Live</div>
          <h4>Think Fast!</h4>
          <p>A Kahoot-style speed trivia game with time-based scoring and real-time leaderboards.</p>
        </div>
        <div class="game-item">
          <div class="game-item-status live">Live</div>
          <h4>AI Game Content Generation</h4>
          <p>Create a fully themed game in one click. LLM integration generates custom prompts, questions, and content so hosts can spin up a unique experience in seconds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- RESUME -->
  <section id="resume">
    <div class="section-header" data-num="02">
      <span class="section-num">02 /</span>
      <h2 class="section-title"><span class="section-title-accent">Experience</span></h2>
    </div>
    <div class="resume-inner">
      <div class="resume-col">
        <h3>Work History</h3>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>Full Stack Software Engineer</h4>
            <span class="resume-item-date">2022 – Present</span>
          </div>
          <div class="resume-item-org">Caribou Financial</div>
          <ul>
            <li>Designed a product discount feature in Rails generating $7k+ revenue weekly while simplifying the DB schema</li>
            <li>Built Auth0 integrations for customers and business partners to securely access internal systems</li>
            <li>Created API caches in TypeScript/Node to store vendor requests and responses, preventing outages when 3rd-party services go down</li>
            <li>Patched security vulns across multiple services to unblock SOC2 compliance; wrote the playbook for other engineers to follow</li>
            <li>Only non-staff engineer selected for a pilot tier-2 support rotation</li>
          </ul>
        </div>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>Software Engineer II</h4>
            <span class="resume-item-date">2020 – 2022</span>
          </div>
          <div class="resume-item-org">Medallia</div>
          <ul>
            <li>Built REST and GraphQL APIs in Java for Medallia's core enterprise SaaS product</li>
            <li>Became the go-to engineer for critical business logic areas while simplifying the domain</li>
            <li>Part of on-call rotation to fix customer issues and ship hotfixes</li>
          </ul>
        </div>
      </div>
      <div class="resume-col">
        <h3>Earlier Experience</h3>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>Software Engineer</h4>
            <span class="resume-item-date">2019 – 2020</span>
          </div>
          <div class="resume-item-org">Potomac IT Group</div>
          <ul>
            <li>Contributed to a new web app on Angular / Tomcat / Java</li>
            <li>Mentored new engineers through code reviews and pair programming</li>
          </ul>
        </div>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>Software Engineer</h4>
            <span class="resume-item-date">2017 – 2019</span>
          </div>
          <div class="resume-item-org">CA Technologies</div>
          <ul>
            <li>Led a CLI plugin from proof-of-concept to production release in Node.js</li>
            <li>Built features for an on-prem B2B resource monitoring web app in Angular</li>
          </ul>
        </div>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>Software Engineer</h4>
            <span class="resume-item-date">2016 – 2017</span>
          </div>
          <div class="resume-item-org">Madcap Software</div>
          <ul>
            <li>Developed new features for a technical writing tool including a responsive content resizer</li>
          </ul>
        </div>
        <div class="resume-item">
          <div class="resume-item-header">
            <h4>B.S. Computer Science</h4>
            <span class="resume-item-date">2016</span>
          </div>
          <div class="resume-item-org">UC San Diego</div>
        </div>
        <div style="margin-top: 2rem;">
          <a href="/resume.pdf" class="btn btn-primary" target="_blank">Download Resume PDF</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TECH -->
  <section id="tech" class="hatch">
    <div class="section-header" data-num="03">
      <span class="section-num">03 /</span>
      <h2 class="section-title"><span class="section-title-accent">Technologies</span></h2>
    </div>
    <div class="tech-grid">
      <div class="tech-tag"><span class="dot"></span>Ruby on Rails</div>
      <div class="tech-tag"><span class="dot"></span>Hotwire</div>
      <div class="tech-tag"><span class="dot"></span>TypeScript</div>
      <div class="tech-tag"><span class="dot"></span>HTML / CSS</div>
      <div class="tech-tag"><span class="dot"></span>PostgreSQL</div>
      <div class="tech-tag"><span class="dot"></span>REST API Design</div>
      <div class="tech-tag"><span class="dot"></span>GraphQL</div>
      <div class="tech-tag"><span class="dot"></span>Node.js</div>
      <div class="tech-tag"><span class="dot"></span>Java</div>
      <div class="tech-tag"><span class="dot"></span>Spring</div>
      <div class="tech-tag"><span class="dot"></span>Docker</div>
      <div class="tech-tag"><span class="dot"></span>Kafka</div>
      <div class="tech-tag"><span class="dot"></span>Terraform</div>
      <div class="tech-tag"><span class="dot"></span>DataDog</div>
      <div class="tech-tag"><span class="dot"></span>Elastic</div>
      <div class="tech-tag"><span class="dot"></span>Unix / Bash</div>
      <div class="tech-tag"><span class="dot"></span>Claude Code</div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="section-header" data-num="04">
      <span class="section-num">04 /</span>
      <h2 class="section-title"><span class="section-title-accent">About Me</span></h2>
    </div>
    <div class="about-layout">
      <div class="about-bio">
        <div class="about-bio-label">The Long Version</div>
<p>Nice to meet you! I'm a dude from SoCal who learned to code a little bit at UCSD. Since then, I've worked as a developer my whole career, and learned to code a lot bit more. Right now I work at <a href="https://caribou.com">Caribou Financial</a>. We fix bad car loans!</p>
          <p>Throughout my career, I've also always volunteered as a mentor for younger people - college students, teens, and kids. I believe that every young person needs loving, stable, adult mentors in their lives. I was fortunate to have many growing up, and now I get to pay it forward to others.</p>
          <p>That mission has taken me to several states - Pittsburgh, Pennsylvania, where I met my wife, then the DC area, then to Ohio to help start a group at 'the' Ohio State University, and most recently back to the DC area. Come hang out with me at the monuments or in downtown Vienna!</p>
          <p>At home, I'm a barista to my amazing wife and jungle gym to two beautiful daughters. I also have a small coffee problem and enjoy roasting, grinding, and brewing all the anaerobically processed Ethiopian and South American coffee I can get my hands on.</p>
          <p>Every word of this bio was written by me. The code is another story... AI is very convenient for that :)</p>
      </div>
      <div class="about-funfacts">
        <div class="about-funfacts-label">Fun Facts</div>
        <div class="funfact">
          <span class="funfact-icon">☕</span>
          <p>I once made 15 gallons of cold brew at once in order to sell it for a fundraiser. We didn't quite sell out. But it was close.</p>
        </div>
        <div class="funfact">
          <span class="funfact-icon">🖋️</span>
            <p>My major was Computer Science, but my favorite college class was playwriting. Since then, I've written or contributed as an editor to several skits and one-act plays that have been performed live for groups of 50-100+ people.</p>
        </div>
        <div class="funfact">
          <span class="funfact-icon">🏕</span>
            <p>I've spent 10+ years volunteering with teenagers on a weekly basis. Worth it!</p>
          </div>
           <div class="funfact">
        <span class="funfact-icon">📖</span>
            <p>My favorite Youtube Channel is the <a href="https://www.youtube.com/@bibleproject">Bible Project</a>. Whether you're Christian or not, they're super engaging and relevant videos about the meaning and history of scripture.</p>
        </div>
        <div class="funfact">
          <span class="funfact-icon">🎸</span>
            <p>I didn't build software in high school, but I did build a working full-scale electric bass in woodshop.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-name">Jack <span>Hartzler</span></div>
    <ul class="footer-links">
        <li><a href="https://github.com/jhartzler">GitHub</a></li>
      <li><a href="https://www.linkedin.com/in/jack-hartzler/">LinkedIn</a></li>
      <li><a id="email-link" href="#">Email</a></li>
    </ul>
    <div class="footer-copy">© 2026 jack.hartzler.dev</div>
  </footer>

  <script>
    // ── Custom cursor ─────────────────────────────────────
    const cursor = document.getElementById('cursor')!;
    document.addEventListener('mousemove', e => {
      cursor.style.left = e.clientX + 'px';
      cursor.style.top  = e.clientY + 'px';
    });
    document.querySelectorAll('a, button, .tech-tag, .funfact, .game-item, nav ul li a').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.classList.add('hover'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('hover'));
    });

    // ── Photo sepia reveal ────────────────────────────────
    const photoFrame = document.querySelector('.photo-frame') as HTMLElement | null;
    const photoSepia = document.querySelector('.photo-sepia') as HTMLElement | null;
    if (photoFrame && photoSepia) {
      let radius = 70;
      let x = 0, y = 0;
      let growing = false;
      let raf: number | null = null;

      const updateMask = () => {
        const feather = radius + 20;
        const mask = `radial-gradient(circle at ${x}px ${y}px, transparent 0px, transparent ${radius}px, black ${feather}px)`;
        photoSepia.style.maskImage = mask;
        photoSepia.style.webkitMaskImage = mask;

        if (growing && radius < 600) {
          radius += 3;
          raf = requestAnimationFrame(updateMask);
        } else {
          raf = null;
        }
      };

      photoFrame.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = photoFrame.getBoundingClientRect();
        x = e.clientX - rect.left;
        y = e.clientY - rect.top;
        if (!growing) {
          growing = true;
          radius = 70;
        }
        if (!raf) raf = requestAnimationFrame(updateMask);
      });

      photoFrame.addEventListener('mouseleave', () => {
        growing = false;
        radius = 70;
        if (raf) { cancelAnimationFrame(raf); raf = null; }
        photoSepia.style.maskImage = '';
        photoSepia.style.webkitMaskImage = '';
      });
    }

    // ── Parallax ghost letter ──────────────────────────────
    const ghost = document.getElementById('ghostLetter') as HTMLElement | null;
    const heroRight = ghost?.closest('.hero-right') as HTMLElement | null;
    if (heroRight && ghost) {
      heroRight.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = heroRight.getBoundingClientRect();
        const cx = (e.clientX - rect.left) / rect.width  - 0.5;
        const cy = (e.clientY - rect.top)  / rect.height - 0.5;
        ghost.style.transform = `translate(${cx * 18}px, ${cy * 12}px)`;
      });
      heroRight.addEventListener('mouseleave', () => {
        ghost.style.transform = '';
      });
    }

    // ── Typewriter ────────────────────────────────────────
    const typeTarget = 'Full Stack Software Engineer';
    const typeEl = document.getElementById('typewriter-text')!;
    const typeCursor = document.querySelector('.typewriter-cursor') as HTMLElement;
    let i = 0;
    const type = () => {
      if (i < typeTarget.length) {
        typeEl.textContent += typeTarget[i++];
        setTimeout(type, 55);
      } else {
        typeCursor.classList.add('typewriter-cursor--done');
      }
    };
    setTimeout(type, 700);

    // ── Section number count-up ───────────────────────────
    const sectionHeaders = document.querySelectorAll<HTMLElement>('.section-header');
    sectionHeaders.forEach(h => {
      h.dataset.target = h.dataset.num!;
      h.dataset.num = '00';
    });
    const numObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const header = entry.target as HTMLElement;
        const target = parseInt(header.dataset.target!);
        let current = 0;
        const tick = setInterval(() => {
          current++;
          header.dataset.num = current.toString().padStart(2, '0');
          if (current >= target) clearInterval(tick);
        }, 80);
        numObserver.unobserve(header);
      });
    }, { threshold: 0.4 });
    sectionHeaders.forEach(h => numObserver.observe(h));

    // ── Obfuscated email ──────────────────────────────────
    const _u = ['j','a','c','k'].join('');
    const _d = ['h','a','r','t','z','l','e','r','.','d','e','v'].join('');
    const _e = _u + '@' + _d;
    const emailLink = document.getElementById('email-link');
    if (emailLink) {
      emailLink.setAttribute('href', 'mai' + 'lto:' + _e);
    }

    // ── Console easter egg ────────────────────────────────
    console.log(
      '%c     ██╗  █████╗  ██████╗ ██╗  ██╗\n' +
      '     ██║ ██╔══██╗ ██╔════╝ ██║ ██╔╝\n' +
      '     ██║ ███████║ ██║      █████╔╝ \n' +
      '██   ██║ ██╔══██║ ██║      ██╔═██╗ \n' +
      '╚█████╔╝ ██║  ██║ ╚██████╗ ██║  ██╗\n' +
      ' ╚════╝  ╚═╝  ╚═╝  ╚═════╝ ╚═╝  ╚═╝',
      'color:#c4622d;font-family:monospace;font-size:11px;line-height:1.5'
    );
    console.log(
      '%c██╗  ██╗  █████╗  ██████╗  ████████╗███████╗ ██╗      ███████╗ ██████╗ \n' +
      '██║  ██║ ██╔══██╗ ██╔══██╗ ╚══██╔══╝╚════██║ ██║      ██╔════╝ ██╔══██╗\n' +
      '███████║ ███████║ ██████╔╝    ██║       ██╔╝  ██║      █████╗   ██████╔╝\n' +
      '██╔══██║ ██╔══██║ ██╔══██╗    ██║      ██╔╝   ██║      ██╔══╝   ██╔══██╗\n' +
      '██║  ██║ ██║  ██║ ██║  ██║    ██║     ██████╗ ███████╗ ███████╗ ██║  ██║\n' +
      '╚═╝  ╚═╝ ╚═╝  ╚═╝ ╚═╝  ╚═╝    ╚═╝     ╚═════╝ ╚══════╝ ╚══════╝ ╚═╝  ╚═╝',
      'color:#d4956a;font-family:monospace;font-size:11px;line-height:1.5'
    );
    console.log(
      '%cCaught you looking at devtools. 👀\nHope you enjoyed the site — let\'s connect!\n%c→ ' + _e,
      'color:#8a7355;font-family:monospace;font-size:13px;line-height:1.8',
      'color:#c4622d;font-family:monospace;font-size:13px;font-weight:bold'
    );
  </script>

</body>
</html>

<style>
  :root {
    --sand:      #f0e8d8;
    --cream:     #faf6ee;
    --ink:       #1a1208;
    --olive:     #c4622d;
    --moss:      #8b3a18;
    --gold:      #d4956a;
    --gold-pale: #f5e6d8;
    --warm-mid:  #8a7355;
    --border:       3px solid var(--ink);
    --border-thick: 5px solid var(--ink);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  /* CUSTOM CURSOR */
  body { cursor: none; }
  #cursor {
    width: 12px; height: 12px;
    background: var(--olive);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: transform 0.08s ease, background 0.2s;
    mix-blend-mode: multiply;
  }
  #cursor.hover {
    transform: translate(-50%, -50%) scale(3);
    background: var(--gold);
  }

  body {
    background: var(--sand);
    color: var(--ink);
    font-family: 'Epilogue', sans-serif;
  }

  /* GRAIN */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9000;
  }

  /* HATCH PATTERN */
  .hatch {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 6px,
      rgba(196,98,45,0.07) 6px,
      rgba(196,98,45,0.07) 7px
    );
  }

  /* ─── NAV ─────────────────────────────────── */
  nav {
    border-bottom: var(--border-thick);
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-family: 'DM Mono', monospace;
    font-weight: 500;
    font-size: 1rem;
    padding: 1rem 2rem 1rem 0;
    border-right: var(--border);
    letter-spacing: -0.02em;
  }
  .nav-logo span { color: var(--olive); }

  nav ul { display: flex; list-style: none; }
  nav ul li a {
    display: block;
    padding: 1.2rem 1.4rem;
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-left: var(--border);
    transition: background 0.12s, color 0.12s;
  }
  nav ul li a:hover {
    background: var(--olive);
    color: var(--cream);
  }

  /* ─── TICKER ─────────────────────────────── */
  .ticker-bar {
    background: var(--moss);
    color: var(--gold);
    padding: 0.6rem 0;
    overflow: hidden;
    border-bottom: var(--border-thick);
  }
  .ticker-track {
    display: flex;
    animation: ticker 22s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
